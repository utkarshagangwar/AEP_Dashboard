# Environment variables / secrets
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
.env.ci
.env.*
!.env.example

# dashboard/.env.example previously had a real (non-placeholder) database
# credential committed into it (found 2026-07-15) and is apparently used
# locally as a real, filled-in env file rather than a template — force it
# back under the .env.* ignore rule above so it's never committed again.
# The onboarding template lives at dashboard/.env.sample instead (tracked,
# placeholder values only).
dashboard/.env.example

