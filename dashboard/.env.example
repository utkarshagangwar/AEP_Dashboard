# Database — Neon (cloud PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# Redis (Docker internal)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT — Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin seed (first run only) — Change these to your desired values
FIRST_ADMIN_EMAIL=admin@aep.local
FIRST_ADMIN_PASSWORD=change-me-to-strong-password

# Automation — absolute path to the automation folder containing robot projects
AUTOMATION_ROOT=/absolute/path/to/automation

# Frontend proxy — Next.js → FastAPI (Docker internal)
FASTAPI_URL=http://backend:8000

# AI test runner LLM — set ONE of these keys to enable AI UI testing
# Priority: ANTHROPIC_API_KEY > OPENAI_API_KEY > GOOGLE_API_KEY
# ANTHROPIC_API_KEY=...   (uses claude-3-5-haiku-20241022 by default)
# OPENAI_API_KEY=...          (uses gpt-4o-mini by default)
# GOOGLE_API_KEY=...         (uses gemini-3.5-flash by default — get from aistudio.google.com)
# AI_LLM_MODEL=                  (optional: override the model name, e.g. gemini-2.5-flash-lite)
# ANTHROPIC_API_KEY= Do not have it now.
# OPENAI_API_KEY= Do not have it now.

# Visual QA (Vibe Testing Phase 2-3) — gates /api/v1/visual-audits endpoints.
# When off/unset, the Visual Audit / SOW / Figma sections render nothing in the UI.
VISUAL_AUDIT_ENABLED=true
# GOOGLE_API_KEYS=key1,key2,key3

# Visual QA — LLM router chain (litellm model names). The router mirrors
# GOOGLE_API_KEYS above into GEMINI_API_KEY automatically, so no separate
# Gemini key is needed here. Set OPENROUTER_API_KEY to enable the free
# OpenRouter vision-model fallback in the chain (optional).
# VISUAL_LLM_PRIMARY=gemini/gemini-3.5-flash
# VISUAL_LLM_FALLBACKS=gemini/gemini-2.5-flash,openrouter/qwen/qwen2.5-vl-72b-instruct:free
# VISUAL_LLM_TIMEOUT_S=120
# VISUAL_LLM_MAX_RETRIES=2
# OPENROUTER_API_KEY=

# Figma import (Vibe Testing Phase 4b) — personal access token, read scope
# is enough. Create at figma.com -> Settings -> Security -> Personal access
# tokens. Required only if you use the "Figma File" import feature.
# FIGMA_API_TOKEN=

# Visual QA — pixel-diff Judge tuning (safe defaults; uncomment to override)
# VISUAL_DIFF_THRESHOLD=0.1          # pixelmatch sensitivity (0..1)
# VISUAL_DIFF_MIN_REGION_PX=64       # ignore mismatch clusters smaller than this
# VISUAL_FAIL_MISMATCH_PCT=1.0       # run fails above this mismatch %

# Visual QA — video walkthrough ingestion (Phase 5, Gemini-only path)
# VISUAL_VIDEO_MODEL=gemini-3.5-flash
# VISUAL_VIDEO_FALLBACK=gemini-2.5-flash
# VISUAL_VIDEO_MAX_MB=100
