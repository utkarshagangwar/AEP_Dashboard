# # Database — use localhost (not postgres) since you're running outside Docker
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# # Redis — same reason, localhost
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# # JWT — same values as root .env
# JWT_SECRET_KEY=your-secret-key-here
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7

# # Admin seed
# FIRST_ADMIN_EMAIL=admin@aep.local
# FIRST_ADMIN_PASSWORD=change-me-to-strong-password

# # Automation — path to the directory containing automation projects (e.g. ig_automation).
# # In Docker: /automation (set via Dockerfile ENV).
# # Locally: absolute path to the automation/ folder in the repo.
# AUTOMATION_ROOT=/automation

# # ── Visual QA (Phase 1-2) ────────────────────────────────────────────────
# # Master switch — all /api/v1/visual-audits endpoints return 404 unless true
# VISUAL_AUDIT_ENABLED=true
# # LLM router chain (litellm model names). Swap models here, no code change.
# VISUAL_LLM_PRIMARY=gemini/gemini-3.5-flash
# VISUAL_LLM_FALLBACKS=gemini/gemini-2.5-flash,openrouter/qwen/qwen2.5-vl-72b-instruct:free
# VISUAL_LLM_TIMEOUT_S=120
# VISUAL_LLM_MAX_RETRIES=2
# # Provider keys (router mirrors GOOGLE_API_KEY(S) into GEMINI_API_KEY automatically)
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# # Judge tuning
# VISUAL_DIFF_THRESHOLD=0.1          # pixelmatch sensitivity (0..1)
# VISUAL_DIFF_MIN_REGION_PX=64       # ignore mismatch clusters smaller than this
# VISUAL_FAIL_MISMATCH_PCT=1.0       # run fails above this mismatch %
# # Where reference/screenshot/diff images are stored (worker + API must share it)
# VISUAL_DATA_DIR=./visual_qa_data
# # Figma import (Phase 4) — personal access token, read scope is enough.
# # Create at figma.com → Settings → Security → Personal access tokens.
# FIGMA_API_TOKEN=
# # Video walkthrough ingestion (Phase 5) — Gemini-only path (Files API).
# VISUAL_VIDEO_MODEL=gemini-3.5-flash
# VISUAL_VIDEO_FALLBACK=gemini-2.5-flash
# VISUAL_VIDEO_MAX_MB=100
# # ---- Orchestrator ("The Brain") ----------------------------------------
# # Reuses VISUAL_AUDIT_ENABLED as its feature gate - see
# # backend/app/services/orchestrator.py's module docstring for why.
# # Coordinator classifier + tier-selection model pool preferences (optional
# # overrides - sensible defaults are picked automatically from whichever of
# # GOOGLE_API_KEY(S) / OPENROUTER_API_KEY / ANTHROPIC_API_KEY(S) / OPENAI_API_KEY(S)
# # are actually configured; see app/services/model_pool.py).
# ORCHESTRATOR_CHEAP_MODEL=google/gemma-4-26b-a4b-it:free
# # Self-execution thresholds for the Judge's vision-skip rule (percent mismatch).
# # Applies to every judge() call, including the existing standalone
# # POST /api/v1/visual-audits path, not just orchestrated runs.
# VISUAL_SELF_EXEC_LOW_PCT=0.5
# VISUAL_SELF_EXEC_HIGH_PCT=60.0
# VISUAL_JUDGE_SELF_EXEC_ENABLED=true
